# Flask
SECRET_KEY=ganti-dengan-random-secret-yang-panjang

# TiDB Cloud - salin dari menu Connect > General
TIDB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=xxxxxx.root
TIDB_PASSWORD=password_tidb_anda
TIDB_DATABASE=portfolio_jenny
# Starter/Essential umumnya memakai CA sistem. Isi lokasi CA sesuai menu Connect.
# Contoh Windows setelah file CA diunduh:
TIDB_CA_PATH=C:/sertifikat/isrgrootx1.pem

# Alternatif: gunakan satu connection string langsung
# DATABASE_URL=mysql+pymysql://user:password@host:4000/portfolio_jenny?charset=utf8mb4

# Akun admin awal. Ubah sebelum menjalankan init-db.
ADMIN_NAME=Jenny
ADMIN_EMAIL=admin@emailanda.com
ADMIN_PASSWORD=GantiPasswordKuat123!

# Cloudinary
CLOUDINARY_CLOUD_NAME=cloud_name_anda
CLOUDINARY_API_KEY=api_key_anda
CLOUDINARY_API_SECRET=api_secret_anda
CLOUDINARY_FOLDER=portfolio-jenny

# Resend
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=Portfolio Jenny <portfolio@domain-terverifikasi.com>
CONTACT_RECEIVER_EMAIL=emailanda@gmail.com
